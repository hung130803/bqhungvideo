# ============================================================
# AI Content Studio - Cấu hình (copy file này thành .env rồi điền)
# ============================================================

# ---- Chọn LLM provider: ollama | gemini | openai | deepseek ----
# ollama = chạy LOCAL trên máy bạn, FREE, không giới hạn (khuyên dùng nếu có GPU)
LLM_PROVIDER=ollama

# ---- API keys (chỉ cần điền của provider bạn dùng) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
# gemini-flash-latest = khuyên dùng (free tier ~5 lượt/phút trên model mới nhất).
# Lưu ý: free tier RẤT giới hạn — xử lý hàng loạt nhiều video nên dùng key trả phí
# hoặc DeepSeek. Mỗi video M1 chỉ tốn 1 lượt gọi.
GEMINI_MODEL=gemini-flash-latest

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- Ollama (LLM chạy LOCAL — FREE, không giới hạn, không cần mạng) ----
# Cài Ollama: https://ollama.com/download  -> rồi mở PowerShell chạy:
#   ollama pull qwen2.5:7b
# Model gợi ý cho RTX 3060 12GB: qwen2.5:7b (nhanh) hoặc qwen2.5:14b (thông minh hơn)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
# Model NHÌN ĐƯỢC HÌNH (vision) để chấm viral theo khung hình.
# Cần: ollama pull qwen2.5vl:7b   ·   USE_VISION=0 để tắt.
OLLAMA_VL_MODEL=qwen2.5vl:7b
USE_VISION=1

# ---- faster-whisper ----
# Model: tiny | base | small | medium | large-v3
# Để trống = app tự chọn theo phần cứng (resource manager)
WHISPER_MODEL=
# Ngôn ngữ chính của video gốc (vi/en/...). Để trống = tự nhận diện.
WHISPER_LANGUAGE=
# Thiết bị chạy whisper: cpu (mặc định, ỔN ĐỊNH) hoặc cuda (GPU, nhanh hơn
# nhưng cần cài cuDNN — thiếu sẽ làm app sập). Cứ để trống nếu không chắc.
WHISPER_DEVICE=

# ---- Diarization (tùy chọn) ----
# Token HuggingFace để tải model pyannote. Bỏ trống = tắt diarization.
HUGGINGFACE_TOKEN=

# ---- ffmpeg ----
# Để trống nếu ffmpeg đã có trong PATH. Nếu không, ghi đường dẫn tuyệt đối.
FFMPEG_PATH=
FFPROBE_PATH=

# ---- Hiệu năng (để trống = app tự đề xuất theo phần cứng) ----
# Số worker CPU chạy song song
MAX_CPU_WORKERS=
# Encoder: auto | nvenc | libx264
VIDEO_ENCODER=auto
