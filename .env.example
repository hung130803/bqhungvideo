# ============================================================
# BQ Hung Video - Cấu hình (copy file này thành .env rồi điền)
# Để trống = dùng mặc định của app.
# ============================================================

# ---- Chọn LLM provider: groq | ollama | gemini | openai | deepseek ----
# groq  = FREE trên mây, nhanh, khuyên dùng (mặc định) — cần GROQ_API_KEYS bên dưới
# ollama = chạy LOCAL trên máy bạn, FREE, không giới hạn (cần GPU + tải model)
LLM_PROVIDER=groq

# ---- Groq (FREE — lấy key tại https://console.groq.com/keys) ----
# Nhiều key thì mỗi key 1 dòng hoặc cách nhau dấu phẩy (app tự XOAY VÒNG khi hết quota)
GROQ_API_KEYS=
GROQ_LLM_MODEL=llama-3.3-70b-versatile
# Model nghe-chép lời trên Groq (dùng khi WHISPER_PROVIDER=groq)
GROQ_WHISPER_MODEL=whisper-large-v3

# ---- API keys provider khác (chỉ cần điền của provider bạn dùng) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
# Free tier RẤT giới hạn — xử lý hàng loạt nên dùng key trả phí hoặc Groq.
GEMINI_MODEL=gemini-2.5-flash

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ---- Ollama (LLM chạy LOCAL — FREE, không giới hạn, không cần mạng) ----
# Cài: https://ollama.com/download  -> PowerShell:  ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5vl:7b
# Model NHÌN ĐƯỢC HÌNH (vision) để chấm viral theo khung hình (chỉ dùng khi LIGHT_MODE=0)
OLLAMA_VL_MODEL=qwen2.5vl:7b
USE_VISION=1

# ---- CHẾ ĐỘ MÁY YẾU (mặc định BẬT = 1) ----
# 1 = dồn việc lên mây (Groq chép lời + AI cắt), BỎ dò cảnh / phân tích âm thanh /
#     bám khuôn mặt / chấm điểm bằng hình -> máy yếu vẫn chạy nhanh.
# 0 = bật FULL phân tích cục bộ (cần máy khỏe + cài đủ thư viện requirements.txt:
#     faster-whisper, mediapipe, librosa, PySceneDetect...) -> crop 9:16 bám mặt,
#     chấm điểm audio/cảnh chính xác hơn.
LIGHT_MODE=1

# ---- Nghe-chép lời (whisper): local | groq ----
# local = faster-whisper chạy trên máy (cần cài, chính xác, không cần mạng)
# groq  = gửi audio lên Groq (FREE, nhanh, máy yếu nên dùng)
WHISPER_PROVIDER=local
# Model local: tiny | base | small | medium | large-v3. Trống = tự chọn theo máy.
WHISPER_MODEL=
# Ngôn ngữ chính của video (vi/en/...). Trống = tự nhận diện.
WHISPER_LANGUAGE=
# Thiết bị chạy whisper local: cpu (mặc định, ỔN ĐỊNH) hoặc cuda (GPU, nhanh hơn
# nhưng cần cài cuDNN — thiếu sẽ làm app sập). Cứ để trống nếu không chắc.
WHISPER_DEVICE=

# ---- Diarization (tùy chọn, chỉ khi LIGHT_MODE=0) ----
# Token HuggingFace để tải model pyannote. Bỏ trống = tắt tách người nói.
HUGGINGFACE_TOKEN=

# ---- ffmpeg ----
# Để trống nếu ffmpeg đã có trong PATH (bản .exe đã kèm sẵn). Nếu không, ghi
# đường dẫn tuyệt đối tới ffmpeg.exe / ffprobe.exe.
FFMPEG_PATH=
FFPROBE_PATH=

# ---- Hiệu năng (để trống = app tự đề xuất theo phần cứng) ----
# Số luồng PHÂN TÍCH + AI chọn cảnh chạy song song
AI_WORKERS=
# Số luồng CẮT/XUẤT video chạy song song
EXPORT_WORKERS=
# Số worker CPU (giới hạn chung, ít khi cần chỉnh)
MAX_CPU_WORKERS=
# Encoder xuất video: auto | nvenc | libx264
VIDEO_ENCODER=auto
